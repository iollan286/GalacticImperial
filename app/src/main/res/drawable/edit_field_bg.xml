<?xml version="1.0" encoding="utf-8"?>
<!-- Background for enabled/editable input fields.
     Slightly brighter border than the button to signal interactivity. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#0d1a38"/>
            <stroke android:width="1dp" android:color="#5090ff"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0a1428"/>
            <stroke android:width="1dp" android:color="#2a50a0"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>

</selector>
