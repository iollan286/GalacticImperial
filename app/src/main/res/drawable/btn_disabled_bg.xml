<?xml version="1.0" encoding="utf-8"?>
<!--
    Static background for disabled (greyed-out) menu buttons.
    Nearly invisible against the dark background — intentionally dim.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/btn_disabled_bg"/>
    <stroke android:width="1dp" android:color="@color/btn_disabled_border"/>
    <corners android:radius="3dp"/>
</shape>
