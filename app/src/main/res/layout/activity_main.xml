<?xml version="1.0" encoding="utf-8"?>
<!--
    Main menu screen.
    Uses TextViews instead of Buttons to avoid AppCompat's automatic
    button-state styling, which would override our custom drawables.
    The EXIT TextView is clickable; all others are decorative (disabled).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="56dp"
        android:paddingBottom="56dp"
        android:paddingLeft="28dp"
        android:paddingRight="28dp">

        <!-- ── Title ─────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GALACTIC IMPERIAL EXPANSION"
            android:textColor="@color/title_color"
            android:textSize="19sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v0.1  —  MAIN MENU"
            android:textColor="@color/version_color"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:layout_marginBottom="52dp"/>

        <!-- ── Menu buttons ──────────────────────────────── -->

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_new_single"
            style="@style/MenuItemDisabled"
            android:text="NEW SINGLE PLAYER GAME"/>

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_new_multi"
            style="@style/MenuItemDisabled"
            android:text="NEW MULTIPLAYER GAME"/>

        <!-- ACTIVE -->
        <TextView
            android:id="@+id/btn_new_tutorial"
            style="@style/MenuItemActive"
            android:text="NEW TUTORIAL GAME"/>

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_search_multi"
            style="@style/MenuItemDisabled"
            android:text="SEARCH FOR MULTIPLAYER GAMES"/>

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_connect_multi"
            style="@style/MenuItemDisabled"
            android:text="CONNECT TO MULTIPLAYER GAME"/>

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_load"
            style="@style/MenuItemDisabled"
            android:text="LOAD GAME"/>

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_settings"
            style="@style/MenuItemDisabled"
            android:text="GENERAL SETTINGS"/>

        <!-- Disabled -->
        <TextView
            android:id="@+id/btn_help"
            style="@style/MenuItemDisabled"
            android:text="HELP"/>

        <!-- ── Spacer before EXIT ─────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/btn_disabled_border"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"/>

        <!-- ACTIVE — closes the app -->
        <TextView
            android:id="@+id/btn_exit"
            style="@style/MenuItemActive"
            android:text="EXIT"/>

    </LinearLayout>

</ScrollView>
