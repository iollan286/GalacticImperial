<?xml version="1.0" encoding="utf-8"?>
<!--
    State selector for the EXIT button.
    Pressed state is brighter (simulates "lighting up").
    Default state is a dim navy with a subtle blue border.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed / tapped state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_active_bg_pressed"/>
            <stroke android:width="1dp" android:color="@color/btn_active_border_pressed"/>
            <corners android:radius="3dp"/>
        </shape>
    </item>

    <!-- Focused (e.g. hardware keyboard navigation) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_active_bg_pressed"/>
            <stroke android:width="1dp" android:color="@color/btn_active_border_pressed"/>
            <corners android:radius="3dp"/>
        </shape>
    </item>

    <!-- Default (unpressed) state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_active_bg"/>
            <stroke android:width="1dp" android:color="@color/btn_active_border"/>
            <corners android:radius="3dp"/>
        </shape>
    </item>

</selector>
